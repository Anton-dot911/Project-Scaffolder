# {{project_name}} service environment variables. Copy to .env and fill in
# real values; .env is gitignored and must never be committed. The dev, start
# and test:llm-smoke scripts load it via node --env-file-if-exists.
ANTHROPIC_API_KEY=
# Optional override for the llm client's default model.
# LLM_MODEL=
# Optional port for the Fastify server (default 3000).
# PORT=
